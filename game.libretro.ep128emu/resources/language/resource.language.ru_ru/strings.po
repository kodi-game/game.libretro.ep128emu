msgctxt "Addon Summary"
msgid "Enterprise - 64/128 (ep128emu)"
msgstr "Enterprise — 64/128 (ep128emu)"

msgctxt "Addon Description"
msgid "ep128emu is a portable emulator of the Enterprise 64/128, ZX Spectrum 48/128, and Amstrad CPC 464/664/6128 computers."
msgstr "ep128emu — это переносимый эмулятор компьютеров Enterprise 64/128, ZX Spectrum 48/128 и Amstrad CPC 464/664/6128."

msgctxt "#30001"
msgid "Main thread wait (ms)"
msgstr "Ожидание основного потока (мс)"

msgctxt "#30002"
msgid "High sound quality"
msgstr "Высокое качество звука"

msgctxt "#30003"
msgid "Use accelerated SW framebuffer"
msgstr "Использовать ускоренный программный фреймбуфер"

msgctxt "#30004"
msgid "Enable resolution changes (requires restart)"
msgstr "Включить изменение разрешения (требуется перезапуск)"

msgctxt "#30005"
msgid "Border lines to keep when zooming in"
msgstr "Количество сохраняемых граничных строк при увеличении"

msgctxt "#30006"
msgid "System ROM version (Enterprise only)"
msgstr "Версия системного ПЗУ (только Enterprise)"

msgctxt "#30007"
msgid "Player 1 Zoom button"
msgstr "Кнопка увеличения игрока 1"

msgctxt "#30008"
msgid "Player 1 Info button"
msgstr "Информационная кнопка игрока 1"

msgctxt "#30009"
msgid "Player 1 Autofire for button"
msgstr "Автоогонь для кнопки игрока 1"

msgctxt "#30010"
msgid "Player 1 Autofire repeat delay"
msgstr "Задержка повтора автоогня игрока 1"

