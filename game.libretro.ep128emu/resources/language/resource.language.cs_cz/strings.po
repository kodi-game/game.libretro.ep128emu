msgctxt "Addon Summary"
msgid "Enterprise - 64/128 (ep128emu)"
msgstr "Enterprise - 64/128 (ep128emu)"

msgctxt "Addon Description"
msgid "ep128emu is a portable emulator of the Enterprise 64/128, ZX Spectrum 48/128, and Amstrad CPC 464/664/6128 computers."
msgstr "ep128emu je přenositelný emulátor počítačů Enterprise 64/128, ZX Spectrum 48/128 a Amstrad CPC 464/664/6128."

msgctxt "#30001"
msgid "Main thread wait (ms)"
msgstr "Čekání hlavního vlákna (ms)"

msgctxt "#30002"
msgid "High sound quality"
msgstr "Vysoká kvalita zvuku"

msgctxt "#30003"
msgid "Use accelerated SW framebuffer"
msgstr "Používat akcelerovaný softwarový framebuffer"

msgctxt "#30004"
msgid "Enable resolution changes (requires restart)"
msgstr "Povolit změny rozlišení (vyžaduje restart)"

msgctxt "#30005"
msgid "Border lines to keep when zooming in"
msgstr "Řádky okraje ponechané při přiblížení"

msgctxt "#30006"
msgid "System ROM version (Enterprise only)"
msgstr "Verze systémové ROM (pouze Enterprise)"

msgctxt "#30007"
msgid "Player 1 Zoom button"
msgstr "Tlačítko přiblížení hráče 1"

msgctxt "#30008"
msgid "Player 1 Info button"
msgstr "Tlačítko informací hráče 1"

msgctxt "#30009"
msgid "Player 1 Autofire for button"
msgstr "Tlačítko hráče 1 s automatickou střelbou"

msgctxt "#30010"
msgid "Player 1 Autofire repeat delay"
msgstr "Prodleva opakování automatické střelby hráče 1"
